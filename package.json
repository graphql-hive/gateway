{
  "name": "gateway",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "packages/transports/*",
    "packages/plugins/*",
    "packages/executors/*",
    "internal/*",
    "e2e/*"
  ],
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "bench": "vitest bench --project bench",
    "build": "yarn sync-graphql-version-docker && yarn workspaces foreach -A -p run build",
    "bundle": "yarn workspaces foreach -A -p run bundle",
    "check:format": "prettier --check .",
    "check:lint": "eslint 'packages/**/src/**/*.ts'",
    "check:missing-peer-deps": "yarn install | grep YN0002 && exit 1 || exit 0",
    "check:types": "yarn tsc",
    "format": "yarn check:format --write",
    "start": "yarn workspace @graphql-hive/gateway start",
    "sync-graphql-version-docker": "node ./scripts/sync-graphql-version-in-dockerfiles.mjs",
    "test": "vitest --project unit",
    "test:bun": "bun test --bail",
    "test:e2e": "vitest --project e2e --slowTestThreshold 1000",
    "test:leaks": "cross-env \"LEAK_TEST=1\" jest --detectOpenHandles --detectLeaks",
    "test:mem": "vitest --project memtest"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-proposal-decorators": "7.29.7",
    "@babel/plugin-proposal-explicit-resource-management": "7.27.4",
    "@babel/plugin-transform-class-properties": "7.29.7",
    "@babel/plugin-transform-class-static-block": "7.29.7",
    "@babel/plugin-transform-private-methods": "^7.27.1",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "patch:@changesets/cli@npm:2.27.9#~/.yarn/patches/@changesets-cli-npm-2.27.9-5df61a909e.patch",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@langfuse/client": "^5.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.9.1",
    "@yarnpkg/cli": "4.17.0",
    "@yarnpkg/core": "4.9.0",
    "@yarnpkg/plugin-pack": "4.0.3",
    "bun": "1.3.14",
    "cross-env": "10.1.0",
    "eslint": "10.5.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.1.0",
    "graphql": "16.14.0",
    "jest": "30.4.2",
    "node-gyp": "13.0.0",
    "prettier": "3.8.4",
    "prettier-plugin-pkg": "0.22.1",
    "prettier-plugin-sh": "0.18.1",
    "ts-jest": "29.4.11",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "patch:vite-tsconfig-paths@npm:5.1.3#~/.yarn/patches/vite-tsconfig-paths-npm-5.1.3-1736ca1872.patch",
    "vitest": "4.1.7"
  },
  "resolutions": {
    "@apollo/composition": "2.14.0",
    "@apollo/server": "5.5.1",
    "@apollo/subgraph": "2.14.0",
    "@graphql-mesh/types": "0.105.0-alpha-20260506144829-078f04bca926f506a39c0fe9481688863b6caf16",
    "@graphql-tools/delegate": "workspace:*",
    "@isaacs/brace-expansion": "5.0.1",
    "@opentelemetry/otlp-exporter-base@npm:^0.203.0": "patch:@opentelemetry/otlp-exporter-base@npm%3A^0.203.0#~/.yarn/patches/@opentelemetry-otlp-exporter-base-npm-0.203.0-183dcac0e6.patch",
    "@rollup/plugin-node-resolve@npm:^15.2.3": "patch:@rollup/plugin-node-resolve@npm%3A^16.0.1#~/.yarn/patches/@rollup-plugin-node-resolve-npm-16.0.1-2936474bab.patch",
    "@vitest/snapshot": "patch:@vitest/snapshot@npm:^4.1.3#~/.yarn/patches/@vitest-snapshot-npm-4.1.3-new.patch",
    "ansi-color@npm:^0.2.1": "patch:ansi-color@npm%3A0.2.1#~/.yarn/patches/ansi-color-npm-0.2.1-f7243d10a4.patch",
    "body-parser": "2.2.1",
