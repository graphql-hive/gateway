    "protobufjs": "8.2.1",
    "require-in-the-middle": "patch:require-in-the-middle@npm%3A^8.0.0#~/.yarn/patches/require-in-the-middle-npm-8.0.0-0176d6df4b.patch",
    "tar": "7.5.11",
    "tar-fs": "3.1.1",
    "tmp": "0.2.4",
    "tsx": "patch:tsx@npm%3A4.20.3#~/.yarn/patches/tsx-npm-4.20.3-7de67a623f.patch",
    "undici": "7.28.0",
